{
  "manifest_version": 3,
  "name": "CookieEdit++",
  "version": "1.0.0",
  "description": "View, edit, create, and delete cookies for the current tab domain.",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CookieEdit++"
  }
}
